#!/bin/sh
hook_dir="$(dirname "$0")"

if command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -File "$hook_dir/run-hook.ps1" pre-push "$@"
fi

if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$hook_dir/run-hook.ps1" pre-push "$@"
fi

echo "[git-hook:pre-push] PowerShell was not found." >&2
exit 1
